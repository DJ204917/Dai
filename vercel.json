{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "npm run install:all",
  "buildCommand": "npm --prefix frontend run build && npm --prefix backend run build",
  "outputDirectory": "frontend/dist",
  "functions": {
    "api/**/*.js": {
      "maxDuration": 10,
      "includeFiles": [
        "backend/dist/**",
        "backend/node_modules/better-sqlite3/**",
        "backend/node_modules/bindings/**",
        "backend/node_modules/file-uri-to-path/**"
      ]
    }
  },
  "rewrites": [
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
